# Supabase — find these in your project's Settings → API
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Base URL of the deployed app (used in auth email redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Notification providers (all optional — mock adapters run without them) ---
# Push (e.g. Expo push service, for the future mobile app)
# EXPO_ACCESS_TOKEN=
# Email (e.g. Resend)
# RESEND_API_KEY=
# SMS (e.g. Twilio)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
